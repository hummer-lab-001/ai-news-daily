<!DOCTYPE html>
<html lang="ja" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>今日のAIニュース — {{ date_display }}</title>
  <meta name="description" content="日本のAIコンサル実務向け毎朝更新AIニュースダッシュボード" />
  <link rel="manifest" href="manifest.json" />
  <meta name="theme-color" content="#1e40af" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="AI News Daily" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: {} }
    }
  </script>

  <style>
    /* PWAホーム画面アイコン用フォールバック */
    @media (display-mode: standalone) {
      body { padding-top: env(safe-area-inset-top); }
    }
  </style>
</head>

<body class="bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 min-h-screen font-sans">

  <!-- ダークモード切替 -->
  <script>
    if (localStorage.getItem('theme') === 'dark' ||
        (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>

  <!-- ヘッダ -->
  <header class="bg-blue-800 dark:bg-blue-950 text-white shadow-lg sticky top-0 z-10">
    <div class="max-w-2xl mx-auto px-4 py-3 flex items-center justify-between">
      <div>
        <h1 class="text-lg font-bold leading-tight">📰 今日のAIニュース</h1>
        <p class="text-blue-200 text-xs mt-0.5">{{ date_display }} &nbsp;|&nbsp; 最終更新: {{ updated_at }}</p>
      </div>
      <button
        onclick="document.documentElement.classList.toggle('dark'); localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light')"
        class="p-2 rounded-full hover:bg-blue-700 transition"
        aria-label="ダークモード切替"
      >🌙</button>
    </div>
  </header>

  {%- set cat_colors = {
      "実務": "bg-blue-100 text-blue-800",
      "ツール": "bg-green-100 text-green-800",
      "業界": "bg-purple-100 text-purple-800",
      "研究": "bg-gray-100 text-gray-800"
  } -%}
  {%- set star_colors = {
      5: "text-red-500",
      4: "text-orange-400",
      3: "text-yellow-500",
      2: "text-blue-400",
      1: "text-gray-400"
  } -%}

  <main class="max-w-2xl mx-auto px-4 py-6 space-y-10">

    <!-- ===== 必読 TOP10 ===== -->
    <section>
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span class="bg-red-600 text-white text-xs px-2 py-0.5 rounded font-semibold">必読</span>
        TOP {{ must_read|length }}
      </h2>

      {% if must_read %}
      <div class="space-y-4">
        {% for item in must_read %}
        <article class="border-l-4 rounded-lg p-4 shadow-sm {{ item.card_border }} dark:bg-gray-800 dark:border-opacity-60">
          <div class="flex items-start justify-between gap-2 mb-1">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-gray-400 dark:text-gray-500 text-sm font-mono">#{{ item.rank }}</span>
              <span class="inline-block px-2 py-0.5 rounded text-xs font-medium {{ cat_colors.get(item.category, 'bg-gray-100 text-gray-700') }}">{{ item.category }}</span>
            </div>
            <span class="text-sm whitespace-nowrap">
              <span class="{{ star_colors.get(item.importance, 'text-gray-400') }} font-bold">{{ "★" * item.importance }}</span><span class="text-gray-300">{{ "☆" * (5 - item.importance) }}</span>
            </span>
          </div>

          <h3 class="font-bold text-base leading-snug mb-2">
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer"
               class="hover:underline text-blue-700 dark:text-blue-400">
              {{ item.title_ja }}
            </a>
          </h3>

          <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-line mb-2">{{ item.summary_ja }}</p>

          {% if item.consultant_insight %}
          <div class="bg-amber-50 dark:bg-amber-900/30 border border-amber-200 dark:border-amber-700 rounded p-2 text-xs text-amber-800 dark:text-amber-300">
            💼 <strong>実務ポイント:</strong> {{ item.consultant_insight }}
          </div>
          {% endif %}

          <p class="text-xs text-gray-400 dark:text-gray-500 mt-2">出典: {{ item.source_name }}</p>
        </article>
        {% endfor %}
      </div>
      {% else %}
      <p class="text-gray-500">本日の必読記事はありません。</p>
      {% endif %}
    </section>

    <!-- ===== その他注目 ===== -->
    {% if digest %}
    <section>
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span class="bg-gray-500 text-white text-xs px-2 py-0.5 rounded font-semibold">注目</span>
        その他 {{ digest|length }} 件
      </h2>

      <ul class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-800 rounded-lg shadow-sm overflow-hidden">
        {% for item in digest %}
        <li class="px-4 py-3 flex items-start gap-3">
          <span class="mt-0.5 shrink-0 inline-block px-2 py-0.5 rounded text-xs font-medium {{ cat_colors.get(item.category, 'bg-gray-100 text-gray-700') }}">{{ item.category }}</span>
          <div class="min-w-0">
            <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer"
               class="font-medium text-sm text-blue-700 dark:text-blue-400 hover:underline line-clamp-2">
              {{ item.title_ja }}
            </a>
            {% if item.one_liner %}
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{{ item.one_liner }}</p>
            {% endif %}
          </div>
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endif %}

  </main>

  <!-- フッタ -->
  <footer class="max-w-2xl mx-auto px-4 py-8 mt-4 border-t border-gray-200 dark:border-gray-700 text-sm text-gray-500 dark:text-gray-400 space-y-4">

    <!-- バックナンバー -->
    {% if archive_links %}
    <div>
      <h3 class="font-semibold text-gray-700 dark:text-gray-300 mb-2">📂 バックナンバー(直近30日)</h3>
      <ul class="flex flex-wrap gap-2">
        {% for link in archive_links %}
        <li>
          <a href="{{ link.url }}" class="text-blue-600 dark:text-blue-400 hover:underline text-xs">
            {{ link.date }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    <!-- 取得失敗ソース -->
    {% if failed_sources %}
    <div>
      <h3 class="font-semibold text-gray-600 dark:text-gray-400 mb-1">⚠️ 本日取得できなかったソース</h3>
      <ul class="text-xs space-y-0.5">
        {% for src in failed_sources %}
        <li class="text-gray-400">{{ src }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    <p class="text-xs text-center text-gray-400 pt-2">
      AI News Daily — 毎朝6:00 JST 自動更新 &nbsp;|&nbsp;
      <a href="https://github.com/hummer-lab-001/ai-news-daily" class="hover:underline" target="_blank" rel="noopener">GitHub</a>
    </p>
  </footer>

</body>
</html>
